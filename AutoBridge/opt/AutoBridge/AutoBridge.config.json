{
  "global": {
    "pollIntervalSeconds": 10,
    "startDate": "2025-01-01",
    "removeSpaces": true,
    "removeHashtags": true,
    "maxRetries": 2,
    "xmlTagDefault": "MACHNAME",
    "fileExtensions": [".xml", ".csv"],
    "resendFolder": "./resend",
    "fileStabilityWaitMs": 750
  },
  "locations": [
    {
      "id": "steris-root",
      "watchFolder": "/Users/nick/Desktop/DemoWasher",
      "mode": "root",

      "machineCode": "STERIS",

      "washerName": {
        "source": "filename",
        "regex": "^(?<washer>[^_]+)_"
      },

      "multiFile": {
        "enabled": true,
        "groupKeyRegex": "_(?<cycleKey>\\d{6}_\\d{6})\\.",
        "requiredCount": 2,
        "waitForGroupSeconds": 300,
        "primaryFileRegex": "^CYCLE_"
      },

      "onSuccessMove": {
        "enabled": true,
        "destination": "/Users/nick/Desktop/DemoWasher/processed"
      }
    },

    {
      "id": "getinge-subfolders",
      "watchFolder": "/Users/nick/Desktop/DemoWasherSubfolders",
      "mode": "subfolder",

      "machineCode": "GETINGE",

      "washerName": {
        "source": "folder"
      },

      "multiFile": {
        "enabled": false
      },

      "onSuccessMove": {
        "enabled": true,
        "destination": "/Users/nick/Desktop/DemoWasherSubfolders/processed"
      }
    }
  ]
}